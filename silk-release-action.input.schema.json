{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://json.schemastore.org/silk-release-action.input.schema.json",
	"type": "object",
	"properties": {
		"$schema": {
			"type": "string"
		},
		"sbom": {
			"$ref": "#/$defs/SbomConfig"
		}
	},
	"additionalProperties": false,
	"title": "Silk Release Action input config",
	"$defs": {
		"SbomConfig": {
			"type": "object",
			"properties": {
				"supplier": {
					"$ref": "#/$defs/SbomSupplier"
				},
				"authors": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/SbomContact"
					}
				},
				"publisher": {
					"type": "string"
				},
				"copyright": {
					"$ref": "#/$defs/SbomCopyright"
				},
				"documentationUrl": {
					"type": "string"
				}
			},
			"additionalProperties": false
		},
		"SbomSupplier": {
			"type": "object",
			"required": ["name"],
			"properties": {
				"name": {
					"type": "string"
				},
				"url": {
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					]
				},
				"contact": {
					"anyOf": [
						{
							"$ref": "#/$defs/SbomContact"
						},
						{
							"type": "array",
							"items": {
								"$ref": "#/$defs/SbomContact"
							}
						}
					]
				}
			},
			"additionalProperties": false
		},
		"SbomContact": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string"
				},
				"email": {
					"type": "string"
				},
				"phone": {
					"type": "string"
				}
			},
			"additionalProperties": false
		},
		"SbomCopyright": {
			"type": "object",
			"properties": {
				"holder": {
					"type": "string"
				},
				"startYear": {
					"$ref": "#/$defs/Int"
				}
			},
			"additionalProperties": false
		},
		"Int": {
			"type": "integer",
			"description": "an integer",
			"title": "int"
		}
	}
}
